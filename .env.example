# Cisco SD-WAN Forensics Dashboard - Proxy Configuration
# Copy this file to .env and fill in your values:
#   copy .env.example .env       (Windows)
#   cp .env.example .env         (macOS/Linux)
#
# Place the .env file in the same folder as the executable.
# Proxy settings are loaded automatically on startup.
# vManage credentials are always prompted interactively.

# ─── Proxy Settings ─────────────────────────────────────────
# Direct proxy:  http://proxy.company.com:8080
# PAC file URL:  http://autoproxy.company.com/autoproxy.cgi
# The app auto-detects PAC files and resolves the actual proxy.
PROXY_URL=http://autoproxy.cbc.com/autoproxy.cgi
PROXY_USER=DOMAIN\your.username
PROXY_PASS=your-password

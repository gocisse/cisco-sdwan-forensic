# Cisco SD-WAN Forensics Dashboard - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Values set here will be used as defaults. You will only be
# prompted for fields that are left empty.

# ─── vManage Connection ─────────────────────────────────────
VMANAGE_URL=https://tenant2.sdwan.cisco.com
VMANAGE_USERNAME=admin
VMANAGE_PASSWORD=

# ─── App Server ─────────────────────────────────────────────
SDWAN_PORT=8888

# ─── Proxy Settings (leave empty if no proxy needed) ────────
# Direct proxy:  http://proxy.company.com:8080
# PAC file URL:  http://autoproxy.company.com/autoproxy.cgi
# The app auto-detects PAC files and resolves the actual proxy.
PROXY_URL=
PROXY_USER=
PROXY_PASS=
